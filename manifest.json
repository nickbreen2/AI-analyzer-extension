{
  "manifest_version": 3,
  "name": "BirdBot AI",
  "version": "1.0.0",
  "description": "A browser-based AI assistant that analyzes web pages and answers questions using page context",
  "permissions": [
    "sidePanel",
    "activeTab",
    "tabs",
    "scripting",
    "storage",
    "tabGroups"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "BirdBot AI",
    "default_icon": {
      "16": "icons/birdbot-icon-16.png",
      "32": "icons/birdbot-icon-32.png",
      "48": "icons/birdbot-icon-48.png",
      "128": "icons/birdbot-icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "service_worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/birdbot-icon-16.png",
    "32": "icons/birdbot-icon-32.png",
    "48": "icons/birdbot-icon-48.png",
    "128": "icons/birdbot-icon-128.png"
  }
}

